#!/bin/bash -ex

#
# MySQL password-less login
envsubst-only-prefix "MYSQL_" < /etc/mysql/conf.d/credentials.cnf.tpl > /etc/mysql/conf.d/credentials.cnf;
chmod u+rwX,go-rwx /etc/mysql/conf.d/credentials.cnf;

#
# NewRelic CLI configuration
envsubst-only-prefix "NEWRELIC_" < /root/.newrelic/credentials.json.tpl > /root/.newrelic/credentials.json;
envsubst-only-prefix "NEWRELIC_" < /root/.newrelic/default-profile.json.tpl > /root/.newrelic/default-profile.json;
chmod u+rwX,go-rwx /root/.newrelic/*.json;

#
# eJSON keys setup
mkdir -p /opt/ejson/keys/;
for EJSON_KEY in $(jq -rc 'keys[]' <<< "$EJSON_KEYS"); do
  jq -rc '.["'$EJSON_KEY'"]' <<<"$EJSON_KEYS" > "/opt/ejson/keys/$EJSON_KEY";
done

#
# Docker login
if [[ ! -z "$DOCKER_USER" ]] && [[ ! -z "$DOCKER_PASS" ]]; then
   echo "$DOCKER_PASS" | docker login --username "$DOCKER_USER" --password-stdin
fi

#
# AZ defaults setup
envsubst-only-prefix "AZ_" < /etc/azure/config.tpl      | sed 's/%/%%/g' > /etc/azure/config;
envsubst-only-prefix "AZ_" < /etc/azure/credentials.tpl | sed 's/%/%%/g' > /etc/azure/credentials;
chmod u+rwX,go-rwx /etc/azure/credentials;

#
# AZ login
if [[ ! -z "$AZ_CLIENT_SECRET" ]]; then
  az login                                \
    --service-principal                   \
    --username $AZ_CLIENT_ID              \
    --password $AZ_CLIENT_SECRET          \
    --tenant $AZ_TENANT_ID                \
  ;
fi

#
# AZ Docker login
if [[ ! -z "$AZ_REGISTRY" ]]; then
  az acr login --resource-group $AZ_ACR_GROUP;
fi

#
# AZ K8s login
if [[ ! -z "$AZ_K8S_CLUSTER" ]]; then
  az aks get-credentials                  \
    --name $AZ_K8S_CLUSTER                \
    --context=$AZ_K8S_CLUSTER             \
    --resource-group $AZ_AKS_GROUP        \
  ;

  kubelogin convert-kubeconfig            \
    --login spn                           \
    --client-id $AZ_CLIENT_ID             \
    --client-secret $AZ_CLIENT_SECRET     \
    --tenant-id $AZ_TENANT_ID             \
  ;
fi
