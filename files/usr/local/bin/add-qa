#!/bin/bash -ex

[[ -z "$(ls /var/lib/apt/lists)" ]] && apt update;

#
# Install PHP & PHP Modules (& their dependencies)
PACKAGES=$(cat <<LIST
  git
  openssh-client

  php$PHPVS-pcov
  php$PHPVS-phpdbg
  php$PHPVS-xdebug
LIST
);
apt install -y --no-install-recommends $PACKAGES;

# Disable pcov & xdebug since they slow things down
phpdismod pcov xdebug;

#
# Install local-php-security-checker
curl -1fsSL -o /usr/local/bin/local-php-security-checker https://github.com/fabpot/local-php-security-checker/releases/download/v2.0.6/local-php-security-checker_2.0.6_linux_$(dpkg --print-architecture);

#
# Install Snyk CLI
curl -1fsSL -o /usr/local/bin/snyk https://downloads.snyk.io/cli/stable/snyk-linux$([[ "$(dpkg --print-architecture)" == "arm64" ]] && echo "-arm64");

#
# Install all of the global Composer packages.
find /opt -mindepth 2 -maxdepth 2 -type f -name composer.json -exec sh -c 'cd $(dirname {}) && composer install' \;
