#!/bin/bash

export NGINX_ENTRYPOINT_QUIET_LOGS=true;
# Run all executable scripts matching /entrypoint.d/*.{envsh.sh}:
scripts=$(find "/entrypoint.d/" -mindepth 1 -maxdepth 1 -follow -executable -type f \( -iname \*.envsh -o -iname \*.sh \) -print 2>/dev/null | sort -V);
for script in $scripts;
do
  case "$script" in
    *.envsh) source "$script"     ;;
    *.sh   )        "$script" "$@";;
  esac
done


# Daemonize commands as services.
if [[ "$1" == "daemonize" ]]; then
  shift;
  daemonize "$@";

# Run command then exit.
elif [[ ! -z "$1" ]]; then
  "$@"
  exit;

fi


# Run all services until a signal is received.
# - check status of the enabled services every 5s.
# - start stopped services with 3 retries, exit on failure.
# - sleep between checks until an INT, QUIT, or STOP signal is given.
# - shutdown all running services before exiting.
service monitor $ENABLED_SERVICES;
