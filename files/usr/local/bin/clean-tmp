#!/bin/bash -ex

# Mark all new binaries as executable
chmod +x /usr/local/bin/*;

apt autoremove -y --purge;
apt clean;

rm -fr /tmp/*                     \
       /var/cache/apt/archives    \
       /var/cache/npm             \
       /var/lib/apt/lists         \
       /var/tmp/*                 \
       /usr/local/share/.cache/   \
       /root/.{composer,npm,yarm} \
       /root/.cache               \
       /root/.local               \
;
