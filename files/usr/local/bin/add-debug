#!/bin/bash -ex

# Ensure files are reread.
if [[ -d /etc/php/$PHPVS/mods-available ]]; then
  cd /etc/php/$PHPVS/mods-available;
  phpenmod opcache-override;
  /etc/init.d/php-fpm reload;
fi

[[ -z "$(ls /var/lib/apt/lists)" ]] && apt update;

PACKAGES=$(cat <<LIST
  bash-completion
  inetutils-ping
  libmemcached-tools
  mariadb-client
  readline-common
  redis-tools
  telnet
LIST
);
apt install -y --no-install-recommends $PACKAGES;
