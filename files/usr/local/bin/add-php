#!/bin/bash -ex

X_ARCH=$(dpkg --print-architecture)

#
# Add Ondrej Sury's PHP repository @see https://deb.sury.org/
curl -1fsSL -o /etc/apt/trusted.gpg.d/php.gpg https://packages.sury.org/php/apt.gpg;
echo "deb https://packages.sury.org/php/ bookworm main" > /etc/apt/sources.list.d/ondrej-sury.list;

#
# Add NewRelic's repository @see https://docs.newrelic.com/docs/apm/agents/php-agent/installation/php-agent-installation-ubuntu-debian/
curl -1fsSL https://download.newrelic.com/548C16BF.gpg | gpg --dearmor -o /etc/apt/trusted.gpg.d/newrelic.gpg;
echo 'deb http://apt.newrelic.com/debian/ newrelic non-free' > /etc/apt/sources.list.d/newrelic.list;

apt update;

#
# Install PHP & PHP Modules (& their dependencies)
PACKAGES=$(cat <<LIST
  ghostscript
  gifsicle
  imagemagick
  jpegoptim
  optipng
  pngquant

  php$PHPVS-amqp
  php$PHPVS-apcu
  php$PHPVS-bcmath
  php$PHPVS-cli
  php$PHPVS-common
  php$PHPVS-curl
  php$PHPVS-fpm
  php$PHPVS-gd
  php$PHPVS-http
  php$PHPVS-igbinary
  php$PHPVS-imagick
  php$PHPVS-intl
  php$PHPVS-mbstring
  php$PHPVS-mongodb
  php$PHPVS-msgpack
  php$PHPVS-mysql
  php$PHPVS-odbc
  php$PHPVS-pgsql
  php$PHPVS-protobuf
  php$PHPVS-raphf
  php$PHPVS-readline
  php$PHPVS-redis
  php$PHPVS-soap
  php$PHPVS-sqlite3
  php$PHPVS-ssh2
  php$PHPVS-stomp
  php$PHPVS-xml
  php$PHPVS-xsl
  php$PHPVS-yaml
  php$PHPVS-zip
LIST
);
apt install -y --no-install-recommends $PACKAGES;

# Skippable packages (PHP 8.5 doesn't have them)
PACKAGES=$(cat <<LIST
  php$PHPVS-grpc
  php$PHPVS-memcached
  php$PHPVS-opcache
  php$PHPVS-zmq
LIST
);
apt install -y --no-install-recommends $PACKAGES || true;

#
# Install NewRelic PHP agent (only for AMD64)
[[ "$X_ARCH" == "amd64" ]] && apt -y install newrelic-php5 && phpdismod newrelic;

#
# Use PEAR & PECL packages
apt install -y --no-install-recommends make php$PHPVS-dev php-pear;
pecl channel-update pecl.php.net;
# Install TimezoneDB
pecl install timezonedb && phpenmod timezonedb;
# Remove PEAR & PECL
apt remove -y make php$PHPVS-dev php-pear;

#
# Install Composer
curl -1fsSL https://getcomposer.org/installer | php -- --2   --install-dir=/usr/local/bin --filename=composer;

#
# Setup NGINX
# Work as www-data
sed -i 's/user  nginx;/user www-data;/' /etc/nginx/nginx.conf;
# Redirect output to stdout & stderr
ln -sfn /proc/1/fd/1 /var/log/nginx/access.log;
ln -sfn /proc/1/fd/2 /var/log/nginx/error.log;
# Move NGINX entrypoint autoconfiguration scripts to /entrypoint.d/
cd /docker-entrypoint.d/;
for script in *.{envsh,sh}; do mv "$script" "/entrypoint.d/10-nginx-$script"; done;
mv /entrypoint.d/10-nginx-15-local-resolvers.envsh /entrypoint.d/10-nginx-15-local-resolvers.sh;
rm -fr /docker-entrypoint.sh /docker-entrypoint.d;

#
# Allow ImageMagick to handle PDF files
sed -i '/<policy domain="coder" rights="none" pattern="PDF" \/>/d' /etc/ImageMagick-6/policy.xml;

#
# Setup PHP-FPM
# Use a version neutral service name
ln -sfn /etc/init.d/php?.?-fpm /etc/init.d/php-fpm;
# Redirect output to stdout & stderr
ln -sfn /proc/1/fd/2 /var/log/php$PHPVS-fpm.log;
# Use a short name for newrelic
ln -sfn /etc/init.d/newrelic-daemon /etc/init.d/newrelic;
